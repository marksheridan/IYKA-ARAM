# ─── IYKA-ARAM Wellness — environment variables ───
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# PostgreSQL connection (managed Postgres — Neon, Supabase, etc.)
# Used by Prisma (CLI + runtime driver adapter).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── Auth.js (wired in Phase 3) ───
# AUTH_SECRET="generate with: npx auth secret"
# AUTH_URL="http://localhost:3000"

# ─── WhatsApp Business API (wired in the final phase) ───
# Provided by the chosen BSP (AiSensy / Interakt / Gupshup).
# WHATSAPP_API_BASE=""
# WHATSAPP_API_KEY=""
# WHATSAPP_PHONE_NUMBER_ID=""
