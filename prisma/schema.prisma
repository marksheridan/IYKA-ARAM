// IYKA-ARAM Wellness — data model
// Mirrors §5.3 of docs/IYKA-ARAM-Work-Plan.md
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (CLI) and is passed
  // to PrismaClient via a driver adapter at runtime (see src/lib/db.ts).
}

// ─────────────────────────────────────────────────────────────
// Auth & people
// ─────────────────────────────────────────────────────────────

// MIS login accounts. Auth.js (NextAuth) Prisma-adapter compatible
// so wiring real auth in Phase 3 is plug-and-play.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(FRONT_DESK)
  passwordHash  String? // optional credentials login

  // a DOCTOR user links to their Staff/Provider record
  staff   Staff?  @relation(fields: [staffId], references: [id])
  staffId String? @unique

  accounts Account[]
  sessions Session[]

  // audit trails
  invoicesCreated Invoice[] @relation("InvoiceCreatedBy")
  paymentsTaken   Payment[] @relation("PaymentRecordedBy")
  expensesLogged  Expense[] @relation("ExpenseRecordedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Auth.js adapter models (used from Phase 3)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Doctors, therapists, yoga instructors, nutritionists.
// Instructors do NOT get a User login (front-desk manages on their behalf).
model Staff {
  id          String       @id @default(cuid())
  name        String
  type        ProviderType
  specialties String[]
  bio         String?
  photoUrl    String?
  email       String?
  phone       String?
  isPublic    Boolean      @default(true) // show on the website
  isActive    Boolean      @default(true)

  user              User?
  services          Service[]          @relation("ServiceProviders")
  availability      Availability[]
  timeBlocks        TimeBlock[]
  appointments      Appointment[]
  classSchedules    ClassSchedule[]
  classOccurrences  ClassOccurrence[]
  consultationNotes ConsultationNote[]
  payouts           Payout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Service catalogue & scheduling
// ─────────────────────────────────────────────────────────────

model Service {
  id               String      @id @default(cuid())
  name             String
  type             ServiceType
  mode             ServiceMode @default(OFFLINE)
  durationMin      Int         @default(30)
  price            Decimal     @db.Decimal(10, 2)
  requiresProvider Boolean     @default(true)
  description      String?
  isActive         Boolean     @default(true)

  providers      Staff[]         @relation("ServiceProviders")
  appointments   Appointment[]
  classSchedules ClassSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Weekly recurring working hours for a provider.
model Availability {
  id        String @id @default(cuid())
  staff     Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   String
  dayOfWeek Int // 0=Sunday … 6=Saturday
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  @@index([staffId])
}

// One-off blocked time (holiday, leave, etc.).
model TimeBlock {
  id      String   @id @default(cuid())
  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId String
  start   DateTime
  end     DateTime
  reason  String?

  @@index([staffId])
}

// Recurring group-class definition (yoga). Generates occurrences.
model ClassSchedule {
  id           String      @id @default(cuid())
  service      Service     @relation(fields: [serviceId], references: [id])
  serviceId    String
  instructor   Staff       @relation(fields: [instructorId], references: [id])
  instructorId String
  title        String
  daysOfWeek   Int[] // e.g. [1,3,5]
  startTime    String // "HH:mm"
  durationMin  Int
  capacity     Int         @default(20)
  mode         ServiceMode @default(ONLINE)
  validFrom    DateTime    @default(now())
  validTo      DateTime?
  isActive     Boolean     @default(true)

  occurrences ClassOccurrence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A concrete dated instance of a class that patients book seats in.
model ClassOccurrence {
  id           String                @id @default(cuid())
  schedule     ClassSchedule?        @relation(fields: [scheduleId], references: [id])
  scheduleId   String?
  instructor   Staff                 @relation(fields: [instructorId], references: [id])
  instructorId String
  title        String
  startsAt     DateTime
  durationMin  Int
  capacity     Int
  meetingLink  String?
  status       ClassOccurrenceStatus @default(SCHEDULED)

  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startsAt])
}

// ─────────────────────────────────────────────────────────────
// Patients, bookings & clinical notes
// ─────────────────────────────────────────────────────────────

model Patient {
  id                  String    @id @default(cuid())
  name                String
  phone               String // E.164, e.g. +91…
  email               String?
  gender              String?
  dateOfBirth         DateTime?
  address             String?
  city                String?
  notes               String?
  consentWhatsApp     Boolean   @default(false)
  consentDataHandling Boolean   @default(false)

  appointments      Appointment[]
  enrollments       Enrollment[]
  invoices          Invoice[]
  consultationNotes ConsultationNote[]
  convertedFromLead Lead?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

// 1:1 slot booking — consultations & offline sessions.
model Appointment {
  id          String            @id @default(cuid())
  patient     Patient           @relation(fields: [patientId], references: [id])
  patientId   String
  service     Service           @relation(fields: [serviceId], references: [id])
  serviceId   String
  provider    Staff?            @relation(fields: [providerId], references: [id])
  providerId  String?
  startsAt    DateTime
  endsAt      DateTime
  mode        ServiceMode       @default(OFFLINE)
  status      AppointmentStatus @default(REQUESTED)
  source      BookingSource     @default(WEBSITE)
  reason      String?
  notes       String? // front-desk notes
  meetingLink String?

  consultationNote ConsultationNote?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startsAt])
  @@index([providerId, startsAt])
}

// Seat booking — a patient's place in a class occurrence.
model Enrollment {
  id           String           @id @default(cuid())
  patient      Patient          @relation(fields: [patientId], references: [id])
  patientId    String
  occurrence   ClassOccurrence  @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  occurrenceId String
  status       EnrollmentStatus @default(BOOKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, occurrenceId])
}

// EMR-lite consultation note, authored by the treating doctor.
model ConsultationNote {
  id             String      @id @default(cuid())
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId  String      @unique
  patient        Patient     @relation(fields: [patientId], references: [id])
  patientId      String
  doctor         Staff       @relation(fields: [doctorId], references: [id])
  doctorId       String
  chiefComplaint String?
  notes          String?
  advice         String?
  vitals         Json?
  followUpDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Billing & finance
// ─────────────────────────────────────────────────────────────

model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique // sequential, GST-friendly
  patient   Patient       @relation(fields: [patientId], references: [id])
  patientId String
  status    InvoiceStatus @default(DRAFT)
  subtotal  Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount Decimal       @default(0) @db.Decimal(10, 2)
  discount  Decimal       @default(0) @db.Decimal(10, 2)
  total     Decimal       @default(0) @db.Decimal(10, 2)
  notes     String?
  issuedAt  DateTime?
  dueAt     DateTime?

  createdBy   User?   @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  createdById String?

  lineItems InvoiceLineItem[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2) // GST %
  amount      Decimal @db.Decimal(10, 2)

  // optional links to what was billed
  serviceId String?
  productId String?
}

model Payment {
  id        String        @id @default(cuid())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(CASH)
  reference String?
  paidAt    DateTime      @default(now())

  recordedBy   User?   @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  recordedById String?

  createdAt DateTime @default(now())
}

// What the business owes each provider (salary or per-consult/commission).
model Payout {
  id          String       @id @default(cuid())
  provider    Staff        @relation(fields: [providerId], references: [id])
  providerId  String
  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  expenses    Expense[]
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId  String
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime        @default(now())
  vendor      String?
  description String?
  receiptUrl  String?

  recordedBy   User?   @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  recordedById String?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Storefront (catalogue), leads & messaging
// ─────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  images      String[]
  category    String?
  stock       Int?
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Website enquiries (booking/contact pop-up, product enquiries).
model Lead {
  id                 String       @id @default(cuid())
  name               String
  phone              String
  email              String?
  interest           LeadInterest @default(GENERAL)
  message            String?
  status             LeadStatus   @default(NEW)
  source             String? // page / campaign
  convertedPatient   Patient?     @relation(fields: [convertedPatientId], references: [id])
  convertedPatientId String?      @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Outbound message audit (WhatsApp first, then SMS/email).
model MessageLog {
  id                String         @id @default(cuid())
  channel           MessageChannel @default(WHATSAPP)
  type              MessageType
  recipient         String // phone (E.164) or email
  templateName      String?
  payload           Json?
  status            MessageStatus  @default(QUEUED)
  providerMessageId String?
  error             String?

  relatedPatientId     String?
  relatedAppointmentId String?
  relatedInvoiceId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  FRONT_DESK
  DOCTOR
}

enum ProviderType {
  DOCTOR
  THERAPIST
  INSTRUCTOR
  NUTRITIONIST
}

enum ServiceType {
  CONSULTATION
  OFFLINE_SESSION
  YOGA_CLASS
}

enum ServiceMode {
  OFFLINE
  ONLINE
  BOTH
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum EnrollmentStatus {
  BOOKED
  ATTENDED
  CANCELLED
  NO_SHOW
  WAITLISTED
}

enum ClassOccurrenceStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingSource {
  WEBSITE
  WALK_IN
  PHONE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum PayoutStatus {
  PENDING
  PAID
}

enum LeadInterest {
  CONSULTATION
  YOGA
  OFFLINE_SESSION
  PRODUCT
  GENERAL
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum MessageType {
  BOOKING_CONFIRMATION
  APPOINTMENT_REMINDER
  RESCHEDULE_NOTICE
  CANCELLATION_NOTICE
  CLASS_ENROLLMENT
  INVOICE_RECEIPT
  LEAD_ACK
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}
