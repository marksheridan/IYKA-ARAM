generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  role            Role      @default(FRONT_DESK)
  passwordHash    String?
  staffId         String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accounts        Account[]
  expensesLogged  Expense[] @relation("ExpenseRecordedBy")
  invoicesCreated Invoice[] @relation("InvoiceCreatedBy")
  paymentsTaken   Payment[] @relation("PaymentRecordedBy")
  sessions        Session[]
  staff           Staff?    @relation(fields: [staffId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Staff {
  id                String             @id @default(cuid())
  name              String
  type              ProviderType
  specialties       String[]
  bio               String?
  photoUrl          String?
  email             String?
  phone             String?
  isPublic          Boolean            @default(true)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  appointments      Appointment[]
  availability      Availability[]
  classOccurrences  ClassOccurrence[]
  classSchedules    ClassSchedule[]
  consultationNotes ConsultationNote[]
  payouts           Payout[]
  timeBlocks        TimeBlock[]
  user              User?
  services          Service[]          @relation("ServiceProviders")
}

model Service {
  id               String          @id @default(cuid())
  name             String
  type             ServiceType
  mode             ServiceMode     @default(OFFLINE)
  durationMin      Int             @default(30)
  price            Decimal         @db.Decimal(10, 2)
  requiresProvider Boolean         @default(true)
  description      String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  appointments     Appointment[]
  classSchedules   ClassSchedule[]
  providers        Staff[]         @relation("ServiceProviders")
}

model Availability {
  id        String @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  staff     Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model TimeBlock {
  id      String   @id @default(cuid())
  staffId String
  start   DateTime
  end     DateTime
  reason  String?
  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model ClassSchedule {
  id           String            @id @default(cuid())
  serviceId    String
  instructorId String
  title        String
  daysOfWeek   Int[]
  startTime    String
  durationMin  Int
  capacity     Int               @default(20)
  mode         ServiceMode       @default(ONLINE)
  validFrom    DateTime          @default(now())
  validTo      DateTime?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  occurrences  ClassOccurrence[]
  instructor   Staff             @relation(fields: [instructorId], references: [id])
  service      Service           @relation(fields: [serviceId], references: [id])
}

model ClassOccurrence {
  id           String                @id @default(cuid())
  scheduleId   String?
  instructorId String
  title        String
  startsAt     DateTime
  durationMin  Int
  capacity     Int
  meetingLink  String?
  status       ClassOccurrenceStatus @default(SCHEDULED)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  instructor   Staff                 @relation(fields: [instructorId], references: [id])
  schedule     ClassSchedule?        @relation(fields: [scheduleId], references: [id])
  enrollments  Enrollment[]

  @@index([startsAt])
}

model Patient {
  id                  String             @id @default(cuid())
  name                String
  phone               String
  email               String?
  gender              String?
  dateOfBirth         DateTime?
  address             String?
  city                String?
  notes               String?
  consentWhatsApp     Boolean            @default(false)
  consentDataHandling Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  appointments        Appointment[]
  consultationNotes   ConsultationNote[]
  enrollments         Enrollment[]
  invoices            Invoice[]
  convertedFromLead   Lead?

  @@index([phone])
}

model Appointment {
  id               String            @id @default(cuid())
  patientId        String
  serviceId        String
  providerId       String?
  startsAt         DateTime
  endsAt           DateTime
  mode             ServiceMode       @default(OFFLINE)
  status           AppointmentStatus @default(REQUESTED)
  source           BookingSource     @default(WEBSITE)
  reason           String?
  notes            String?
  meetingLink      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  patient          Patient           @relation(fields: [patientId], references: [id])
  provider         Staff?            @relation(fields: [providerId], references: [id])
  service          Service           @relation(fields: [serviceId], references: [id])
  consultationNote ConsultationNote?

  @@index([startsAt])
  @@index([providerId, startsAt])
}

model Enrollment {
  id           String           @id @default(cuid())
  patientId    String
  occurrenceId String
  status       EnrollmentStatus @default(BOOKED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  occurrence   ClassOccurrence  @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  patient      Patient          @relation(fields: [patientId], references: [id])

  @@unique([patientId, occurrenceId])
}

model ConsultationNote {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  patientId      String
  doctorId       String
  chiefComplaint String?
  notes          String?
  advice         String?
  vitals         Json?
  followUpDate   DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor         Staff       @relation(fields: [doctorId], references: [id])
  patient        Patient     @relation(fields: [patientId], references: [id])
}

model Invoice {
  id          String            @id @default(cuid())
  number      String            @unique
  patientId   String
  status      InvoiceStatus     @default(DRAFT)
  subtotal    Decimal           @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal           @default(0) @db.Decimal(10, 2)
  discount    Decimal           @default(0) @db.Decimal(10, 2)
  total       Decimal           @default(0) @db.Decimal(10, 2)
  notes       String?
  issuedAt    DateTime?
  dueAt       DateTime?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   User?             @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  patient     Patient           @relation(fields: [patientId], references: [id])
  lineItems   InvoiceLineItem[]
  payments    Payment[]
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  amount      Decimal @db.Decimal(10, 2)
  serviceId   String?
  productId   String?
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod @default(CASH)
  reference    String?
  paidAt       DateTime      @default(now())
  recordedById String?
  createdAt    DateTime      @default(now())
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy   User?         @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
}

model Payout {
  id          String       @id @default(cuid())
  providerId  String
  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  provider    Staff        @relation(fields: [providerId], references: [id])
}

model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  expenses    Expense[]
}

model Expense {
  id           String          @id @default(cuid())
  categoryId   String
  amount       Decimal         @db.Decimal(10, 2)
  date         DateTime        @default(now())
  vendor       String?
  description  String?
  receiptUrl   String?
  recordedById String?
  createdAt    DateTime        @default(now())
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  recordedBy   User?           @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  images      String[]
  category    String?
  stock       Int?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id                 String       @id @default(cuid())
  name               String
  phone              String
  email              String?
  interest           LeadInterest @default(GENERAL)
  message            String?
  status             LeadStatus   @default(NEW)
  source             String?
  convertedPatientId String?      @unique
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  convertedPatient   Patient?     @relation(fields: [convertedPatientId], references: [id])
}

model MessageLog {
  id                   String         @id @default(cuid())
  channel              MessageChannel @default(WHATSAPP)
  type                 MessageType
  recipient            String
  templateName         String?
  payload              Json?
  status               MessageStatus  @default(QUEUED)
  providerMessageId    String?
  error                String?
  relatedPatientId     String?
  relatedAppointmentId String?
  relatedInvoiceId     String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([status])
}

enum Role {
  ADMIN
  FRONT_DESK
  DOCTOR
}

enum ProviderType {
  DOCTOR
  THERAPIST
  INSTRUCTOR
  NUTRITIONIST
}

enum ServiceType {
  CONSULTATION
  OFFLINE_SESSION
  YOGA_CLASS
}

enum ServiceMode {
  OFFLINE
  ONLINE
  BOTH
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  IN_CONSULTATION
}

enum EnrollmentStatus {
  BOOKED
  ATTENDED
  CANCELLED
  NO_SHOW
  WAITLISTED
}

enum ClassOccurrenceStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingSource {
  WEBSITE
  WALK_IN
  PHONE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum PayoutStatus {
  PENDING
  PAID
}

enum LeadInterest {
  CONSULTATION
  YOGA
  OFFLINE_SESSION
  PRODUCT
  GENERAL
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum MessageType {
  BOOKING_CONFIRMATION
  APPOINTMENT_REMINDER
  RESCHEDULE_NOTICE
  CANCELLATION_NOTICE
  CLASS_ENROLLMENT
  INVOICE_RECEIPT
  LEAD_ACK
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}
